---

<section class="w-full flex justify-center" id="approach">
  <div class="w-full flex flex-col gap-8 px-50 py-15 bg-neutral-500">
    <h1 class="text-center max-w-2xl mx-auto bg-stone-50 px-6 py-4 rounded-lg shadow-md text-zinc-900 text-4xl font-semibold opacity-70">
      Our Approach
    </h1>
    {items.map((item, index) => (
      <div>
        <div class={`flex items-center gap-4 ${index % 2 === 0 ? "flex-row" : "flex-row-reverse"}`}>
          <div class="w-1/2 flex justify-center">
            <div>
              <p class="text-slate-100 text-7xl font-semibold">{index + 1}.</p>
            </div>
            <div set:html={item.icon}></div>
          </div>
          <div class="w-1/2 text-lg">
            <p class="font-semibold text-xl text-slate-100">{item.title}</p>
            <br/>
            <p class="text-slate-200 text-md">{item.text}</p>
          </div>
        </div>
        {index !== items.length - 1 ? <br><hr class="border-t border-slate-200 my-6" /> : null}
      </div>
    ))}
  </div>
</section>

